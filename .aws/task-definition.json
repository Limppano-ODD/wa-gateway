{
  "family": "wa-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::590183660812:role/wa-gateway-execution-role",
  "taskRoleArn": "arn:aws:iam::590183660812:role/wa-gateway-task-role",
  "volumes": [
    {
      "name": "wa-credentials-volume",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0e0ada9e77d3e6432",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED"
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "wa-gateway",
      "image": "590183660812.dkr.ecr.us-east-1.amazonaws.com/wa-gateway:latest",
      "portMappings": [
        {
          "containerPort": 5001,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/wa-gateway",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "mountPoints": [
        {
          "sourceVolume": "wa-credentials-volume",
          "containerPath": "/app/wa_credentials",
          "readOnly": false
        }
      ],
      "secrets": [
        {
          "name": "NODE_ENV",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:590183660812:secret:wa-gateway-secrets-kI5oEr:NODE_ENV::"
        },
        {
          "name": "PORT",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:590183660812:secret:wa-gateway-secrets-kI5oEr:PORT::"
        },
        {
          "name": "KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:590183660812:secret:wa-gateway-secrets-kI5oEr:KEY::"
        },
        {
          "name": "WEBHOOK_BASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:590183660812:secret:wa-gateway-secrets-kI5oEr:WEBHOOK_BASE_URL::"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:5001/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
